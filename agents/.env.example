# ── Google OAuth (Gmail read access) ────────────────────────────────────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Gmail API
# 3. Create OAuth 2.0 credentials (Desktop App type)
# 4. Run: npm run setup-oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Gemini API (free tier: 15 RPM, 1M tokens/day) ───────────────────────────
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Options: gemini-2.0-flash-lite (cheapest) | gemini-2.0-flash | gemini-1.5-flash
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Supabase (use service role key for server-side writes) ───────────────────
# Found at: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://sozysnvupisjygmwdzej.supabase.co
SUPABASE_SERVICE_KEY=

# ── Agent config ─────────────────────────────────────────────────────────────
GMAIL_USER=rahulpyne90@gmail.com
# Cron schedule (default: 11 PM IST every night)
CRON_SCHEDULE=0 23 * * *
TIMEZONE=Asia/Kolkata
# Minimum LLM importance score (1-10) to create a task
IMPORTANCE_THRESHOLD=6
# How many hours back to fetch emails
LOOKBACK_HOURS=24
# Trash Spam/Promotions/Social/Updates emails older than this many days (default: 7)
CLEAN_OLDER_THAN_DAYS=7
